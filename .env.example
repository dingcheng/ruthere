# Application
APP_NAME=RUThere
BASE_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-random-64-char-string

# Vault encryption key (generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
# This is a base64-encoded 32-byte key used for AES-256-GCM
VAULT_KEY=change-me-generate-a-real-key

# Database
DATABASE_URL=sqlite+aiosqlite:///./ruthere.db

# ntfy.sh push notifications
NTFY_BASE_URL=https://ntfy.sh

# Resend (email)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=heartbeat@yourdomain.com

# Heartbeat defaults
DEFAULT_HEARTBEAT_INTERVAL_HOURS=24
DEFAULT_MISSED_THRESHOLD=3
DEFAULT_RESPONSE_WINDOW_HOURS=4

# Cloudflare Tunnel
TUNNEL_TOKEN=your-tunnel-token-here
